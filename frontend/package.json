{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "check": "vue-tsc --noEmit && eslint .",
    "build": "vue-tsc && vite build --mode production",
    "build:dev": "vue-tsc && vite build --minify false --mode development",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "i18n-report": "vue-i18n-extract report --vueFiles './src/**/*.?(ts|vue)' --languageFiles './src/i18n/*.?(json|yml|yaml|js)'",
    "i18n-add": "vue-i18n-extract report --add --exclude types --vueFiles './src/**/*.?(ts|vue)' --languageFiles './src/i18n/*.?(json|yml|yaml|js)'",
    "i18n-remove": "vue-i18n-extract report --remove --exclude types --vueFiles './src/**/*.?(ts|vue)' --languageFiles './src/i18n/*.?(json|yml|yaml|js)'",
    "devtools": "./node_modules/.bin/vue-devtools"
  },
  "dependencies": {
    "@formkit/tempo": "^0.1.2",
    "@headlessui/vue": "^1.7.23",
    "@heroicons/vue": "^2.2.0",
    "@types/deep-equal": "^1.0.4",
    "@types/lodash": "^4.17.24",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^14.2.1",
    "@wailsio/runtime": "3.0.0-alpha.78",
    "dayjs": "^1.11.20",
    "deep-equal": "^2.2.3",
    "dompurify": "^3.3.3",
    "flag-icons": "^7.5.0",
    "lodash": "^4.17.23",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.30",
    "vue-i18n": "^11.3.0",
    "vue-router": "^4.6.4",
    "vue-tailwind-datepicker": "^1.7.4",
    "vue-toastification": "2.0.0-rc.5",
    "vue3-lottie": "^3.3.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@babel/types": "^7.29.0",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/devtools": "^8.1.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "autoprefixer": "^10.4.27",
    "daisyui": "5.5.3",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.8.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-eslint": "^1.8.1",
    "vue-eslint-parser": "^10.4.0",
    "vue-i18n-extract": "^2.0.7",
    "vue-tsc": "^3.2.6"
  }
}
